root = true

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{yml,yaml,sls}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
indent_size = 2

[Makefile]
indent_style = tab

# install.sh and uninstall.sh use 4-space indentation; the runtime
# motd/*.sh helpers use 2-space to keep the hot-path script compact.
[install.sh]
indent_size = 4

[uninstall.sh]
indent_size = 4

[motd/*.sh]
indent_size = 2
